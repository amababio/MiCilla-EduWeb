generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  initials    String
  tagline     String
  motto       String
  poBox       String
  location    String
  phone       String
  whatsapp    String
  email       String
  officeHours String
  logoUrl     String?
  brandColor  String   @default("#cf85ef")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  websiteSettings WebsiteSettings?
  programs        Program[]
  galleryImages   GalleryImage[]
  achievements    Achievement[]
  announcements   Announcement[]
  downloads       Download[]
  admins          Admin[]
  schoolClasses   SchoolClass[]
  scheduleActivities ScheduleActivity[]
  classTimetableEntries ClassTimetableEntry[]
  examTimetableEntries  ExamTimetableEntry[]
  termCalendarEvents    TermCalendarEvent[]
  dailyRoutineEntries   DailyRoutineEntry[]
}

model WebsiteSettings {
  id                    String   @id @default(cuid())
  schoolId              String   @unique
  school                School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  heroDescription       String
  heroCtaPrimary        String   @default("Apply for Admission")
  heroCtaSecondary      String   @default("Chat on WhatsApp")
  admissionsHeadline    String
  admissionsDescription String
  admissionLevels       Json
  aboutDescription      String
  aboutValues           Json
  whyChooseUsIntro      String   @default("Parents trust us for quality teaching, strong values, and a welcoming school community.")
  whyChooseUs           Json
  achievementsSubtitle  String
  achievementsNote      String
  contactHeadline       String
  contactDescription    String
  contactCtaHeadline    String   @default("Chat with us on WhatsApp")
  contactCtaDescription String   @default("The fastest way to ask about admissions, school visits, and placement availability.")
  poweredByFooter       String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Program {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  description String
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId, sortOrder])
}

model GalleryImage {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  category    String   @default("General")
  accentClass String
  imageUrl    String?
  sortOrder   Int      @default(0)
  isFeatured  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId, sortOrder])
}

model Achievement {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title          String
  description    String
  category       String   @default("school_project")
  privacyDisplay String   @default("hide")
  subjectName    String?
  subjectClass   String?
  sortOrder      Int      @default(0)
  isPublished    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([schoolId, sortOrder])
}

model Announcement {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  category    String
  message     String
  displayDate String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId, sortOrder])
}

model Download {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    String   @default("general")
  fileUrl     String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId, sortOrder])
}

model Admin {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([schoolId, email])
  @@index([email])
}

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SchoolClass {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classTimetableEntries ClassTimetableEntry[]
  examTimetableEntries  ExamTimetableEntry[]

  @@index([schoolId, sortOrder])
}

model ScheduleActivity {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  category  String   @default("subject")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, sortOrder])
}

model ClassTimetableEntry {
  id            String      @id @default(cuid())
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolClassId String
  schoolClass   SchoolClass @relation(fields: [schoolClassId], references: [id], onDelete: Cascade)
  dayOfWeek     String
  periodLabel   String
  startTime     String
  endTime       String
  activityName  String
  sortOrder     Int         @default(0)
  isPublished   Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([schoolId, sortOrder])
}

model ExamTimetableEntry {
  id            String       @id @default(cuid())
  schoolId      String
  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolClassId String?
  schoolClass   SchoolClass? @relation(fields: [schoolClassId], references: [id], onDelete: SetNull)
  subjectName   String
  examDate      String
  startTime     String
  endTime       String
  sortOrder     Int          @default(0)
  isPublished   Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([schoolId, sortOrder])
}

model TermCalendarEvent {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  displayDate String
  description String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId, sortOrder])
}

model DailyRoutineEntry {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timeLabel   String
  title       String
  level       String   @default("all")
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId, sortOrder])
}
