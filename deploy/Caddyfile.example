# Example Caddy reverse proxy with automatic HTTPS.
# 1. Copy to /etc/caddy/Caddyfile (or include from there)
# 2. Point your domain A record to this VPS
# 3. sudo systemctl reload caddy

your-school-domain.com {
	encode gzip zstd

	@health path /api/health
	handle @health {
		reverse_proxy 127.0.0.1:3000
	}

	reverse_proxy 127.0.0.1:3000
}

# Optional: serve a second school on a subdomain
# grace.your-school-domain.com {
# 	reverse_proxy 127.0.0.1:3000
# }
