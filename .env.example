# Copy to .env for local development or production on your VPS.
# Never commit real secrets.

# --- Required ---
DATABASE_URL="postgresql://micilla:change-me@localhost:5432/micilla_eduweb?schema=public"
DEFAULT_SCHOOL_SLUG="redemption-international-school"
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# --- Server ---
NODE_ENV="production"
PORT="3000"

# --- Local development seed (optional; do not seed demo passwords in production) ---
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin123!"
SEED_SUPER_ADMIN_EMAIL="super@micilla.com"
SEED_SUPER_ADMIN_PASSWORD="super123!"

# --- Database backup script (deploy/backup-db.sh) ---
BACKUP_DIR="/var/backups/micilla-eduweb"
BACKUP_RETENTION_DAYS="14"
