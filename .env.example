# Copy to .env and adjust if needed
DATABASE_URL="postgresql://micilla:micilla@localhost:5435/micilla_eduweb?schema=public"

# Default demo school slug served at /
DEFAULT_SCHOOL_SLUG="redemption-international-school"

# Session signing secret (use a long random string in production)
SESSION_SECRET="change-this-to-a-long-random-secret"

# Seed admin account (used by npm run db:seed)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin123!"

# Seed MiCilla super admin account
SEED_SUPER_ADMIN_EMAIL="super@micilla.com"
SEED_SUPER_ADMIN_PASSWORD="super123!"
